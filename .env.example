# API Configuration
NEXT_PUBLIC_API_URL=https://api.clawbrowser.ai

# Auth0 Configuration (server-side only)
AUTH0_SECRET=<generate-a-secret>
AUTH0_BASE_URL=https://clawbrowser.ai
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=<your-auth0-client-id>
AUTH0_CLIENT_SECRET=<your-auth0-client-secret>

# Feature Flag Overrides (optional)
# NEXT_PUBLIC_FF_ONBOARDING=false
# NEXT_PUBLIC_FF_DOCS=false
# NEXT_PUBLIC_FF_QUICKSTART_SNIPPETS=false
# NEXT_PUBLIC_FF_CHANGELOG=false
# NEXT_PUBLIC_FF_SUPPORT=false
